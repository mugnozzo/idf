{
  "name": "idf",
  "version": "0.1.0",
  "description": "backend/server.js",
  "scripts": {
    "db:init": "node init-db.js",
    "db:reset": "node reset-db.js",
    "db:rebuild": "npm run db:reset && npm run db:init",
    "dev": "concurrently -n backend,frontend -c red,blue \"npm run backend\" \"npm run frontend\"",
